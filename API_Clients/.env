#Variables d'environnement pour l'API Clients
# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=clientsdb
# URL de connexion à la BDD (utilisée par FastAPI)
DATABASE_URL=postgresql://postgres:root@db:5432/clientsdb

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Environnement de l’application
APP_ENV=prod
# Chemin vers le fichier de configuration YAML
CONFIG_PATH=/app/config.yaml